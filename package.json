{
  "name": "gatsby-starter-hello-world",
  "private": true,
  "description": "A simplified bare-bones starter for Gatsby",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "build": "gatsby build",
    "develop": "gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1",
    "deploy": "gatsby build && gh-pages -d public -b master"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^1.3.0",
    "@fortawesome/free-brands-svg-icons": "^6.0.0",
    "@fortawesome/free-solid-svg-icons": "^6.0.0",
    "@fortawesome/react-fontawesome": "^0.1.17",
    "bootstrap": "^5.1.3 ",
    "gatsby": "^4.9.1",
    "gatsby-plugin-disqus": "^1.2.3",
    "gatsby-plugin-google-analytics": "^4.9.0",
    "gatsby-plugin-manifest": "^4.9.0",
    "gatsby-plugin-react-helmet": "^5.9.0",
    "gatsby-plugin-sass": "^5.9.0",
    "gatsby-plugin-web-font-loader": "*",
    "gatsby-remark-component": "*",
    "gatsby-remark-prismjs": "^6.9.0",
    "gatsby-source-filesystem": "^4.9.0",
    "gatsby-transformer-remark": "^5.9.0",
    "gh-pages": "^3.2.3",
    "node-sass": "^6.0.1",
    "prismjs": "^1.27.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-fontawesome": "^1.7.1",
    "react-helmet": "^6.1.0",
    "gatsby-plugin-postcss" : "^3.7.0"
  },
  "devDependencies": {
    "prettier": "^1.19.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gatsbyjs/gatsby-starter-hello-world"
  },
  "bugs": {
    "url": "https://github.com/gatsbyjs/gatsby/issues"
  }
}
